# OpenSec Lab — Configuración
# Copia este archivo como .env y ajusta los valores que necesites.
# La mayoría de los valores por defecto funcionan sin cambios para uso en laboratorio.

# ─── Dominio y red ───────────────────────────────────────────────────────────

OPSN_DOMAIN=opensec.lab
OPSN_NETWORK_NAME=openseclab

# ─── Credenciales ────────────────────────────────────────────────────────────

# Contraseña del panel de administración de Technitium DNS
OPSN_DNS_PASSWORD=Password

# Contraseña del servidor de correo (Roundcube webmail + Thunderbird)
OPSN_MAIL_PASSWORD=Password

# Contraseña de GoPhish se genera automáticamente al iniciar (se muestra en los logs)

# ─── Puertos en el host ──────────────────────────────────────────────────────

OPSN_DNS_CONSOLE_PORT=5380
OPSN_DVWA_PORT=8080
OPSN_JUICE_PORT=3000
OPSN_GOPHISH_ADMIN_PORT=3333
OPSN_GOPHISH_PHISH_PORT=80
OPSN_DESKTOP_PORT=3100
OPSN_DESKTOP_HTTPS_PORT=3101
OPSN_MAIL_WEBMAIL_PORT=8888

# ─── GoPhish — campaña pre-configurada ──────────────────────────────────────

OPSN_GOPHISH_SMTP_PORT=25

# Nombre visible del remitente en los correos de phishing
OPSN_GOPHISH_FROM_NAME=Soporte IT

# ─── GoPhish — identidad de empresa ficticia ─────────────────────────────────

# Nombre de la empresa simulada (aparece en email, landing page y recursos)
OPSN_GOPHISH_COMPANY_NAME=Acme Corp

# Asunto del correo de phishing
OPSN_GOPHISH_EMAIL_SUBJECT=Accion requerida: Restablece tu contrasena corporativa

# Firma del correo (nombre del equipo remitente)
OPSN_GOPHISH_SUPPORT_TEAM=Equipo de Seguridad IT

# ─── Tier 1: Targets vulnerables adicionales ─────────────────────────────────

# Puerto de WebGoat (plataforma de aprendizaje guiado OWASP)
OPSN_WEBGOAT_PORT=8081

# ─── Tier 2: Gamificacion y Aprendizaje ──────────────────────────────────────

# CTFd — Plataforma de retos CTF
OPSN_CTFD_PORT=8000
OPSN_CTFD_ADMIN_PASSWORD=Password
# Clave secreta de Flask para CTFd (cambiar en producción)
OPSN_CTFD_SECRET_KEY=opensec-lab-ctfd-secret-key-change-me
OPSN_CTFD_DB_PASSWORD=ctfd_db_password

# Gitea — Repositorios con codigo vulnerable para code review
OPSN_GITEA_PORT=3002
OPSN_GITEA_SSH_PORT=2222
OPSN_GITEA_PASSWORD=Password
OPSN_GITEA_ADMIN_USER=admin

# Portal central — Dashboard con links a todos los servicios
OPSN_PORTAL_PORT=8443

# ─── Tier 3: Blue Team — Wazuh SIEM + Suricata IDS ─────────────────
# IMPORTANTE: Requiere 12+ GB RAM y vm.max_map_count=262144 en el host.
# Antes de instalar ejecuta:
#   sudo sysctl -w vm.max_map_count=262144
#   echo 'vm.max_map_count=262144' | sudo tee -a /etc/sysctl.conf

# Contraseña del admin del Wazuh Indexer y Dashboard
# Requisitos Wazuh: 8+ chars, mayúsculas, minúsculas, dígito, símbolo ($-_%@?.*&)
OPSN_WAZUH_PASSWORD=Password1.

# Contraseña del usuario API wazuh-wui (el Dashboard se conecta al Manager con este usuario)
OPSN_WAZUH_API_PASSWORD=WazuhApiP4ss.

# Puerto del Wazuh Dashboard (interfaz web HTTPS)
OPSN_WAZUH_DASH_PORT=5601

# Puerto de la API REST del Wazuh Manager
OPSN_WAZUH_API_PORT=55000

# Interfaz de red que Suricata monitorea
# "any" captura en todas las interfaces (más fácil para el lab)
# Para monitorear solo la red Docker, detecta el bridge con:
#   docker network inspect openseclab | grep '"Name"' && ip link show | grep br-
OPSN_SURICATA_INTERFACE=any
