<!-- OpenSec Lab — Reglas personalizadas de Wazuh -->
<!-- Detecta actividad de ataque en los servicios del laboratorio -->
<!-- Rule IDs reservados: 100001-100099 (OpenSec Lab) -->
<group name="openseclab,">

  <!-- ══ DVWA ══════════════════════════════════════════════════════ -->

  <rule id="100001" level="10">
    <if_sid>31108</if_sid>
    <url>/vulnerabilities/sqli</url>
    <description>OpenSecLab: Posible SQL Injection en DVWA (/vulnerabilities/sqli)</description>
    <group>attack,sql_injection,openseclab_dvwa,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100002" level="10">
    <if_sid>31108</if_sid>
    <url>/vulnerabilities/exec</url>
    <description>OpenSecLab: Posible Command Injection en DVWA (/vulnerabilities/exec)</description>
    <group>attack,openseclab_dvwa,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <rule id="100003" level="8">
    <if_sid>31108</if_sid>
    <url>/vulnerabilities/xss</url>
    <description>OpenSecLab: Posible XSS en DVWA (/vulnerabilities/xss)</description>
    <group>attack,xss,openseclab_dvwa,</group>
    <mitre>
      <id>T1059.007</id>
    </mitre>
  </rule>

  <rule id="100004" level="8">
    <if_sid>31108</if_sid>
    <url>/vulnerabilities/fi</url>
    <description>OpenSecLab: Posible File Inclusion en DVWA (/vulnerabilities/fi)</description>
    <group>attack,openseclab_dvwa,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ══ OWASP Juice Shop ══════════════════════════════════════════ -->

  <rule id="100010" level="6">
    <if_sid>31108</if_sid>
    <url>/score-board</url>
    <description>OpenSecLab: Acceso al Score Board de Juice Shop (reto de descubrimiento)</description>
    <group>openseclab_juiceshop,</group>
  </rule>

  <rule id="100011" level="10">
    <if_sid>31108</if_sid>
    <url>/rest/user/login</url>
    <match>OR 1=1</match>
    <description>OpenSecLab: Intento de SQL Injection en login de Juice Shop</description>
    <group>attack,sql_injection,openseclab_juiceshop,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100012" level="8">
    <if_sid>31108</if_sid>
    <url>/api/Feedbacks</url>
    <description>OpenSecLab: Actividad en endpoint de Feedbacks de Juice Shop</description>
    <group>openseclab_juiceshop,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- ══ GoPhish ═══════════════════════════════════════════════════ -->

  <rule id="100020" level="7">
    <if_sid>31108</if_sid>
    <url>/track</url>
    <description>OpenSecLab: Click en landing page de GoPhish registrado</description>
    <group>openseclab_gophish,phishing,</group>
    <mitre>
      <id>T1566</id>
    </mitre>
  </rule>

  <!-- ══ WebGoat ════════════════════════════════════════════════════ -->

  <rule id="100030" level="3">
    <if_sid>31108</if_sid>
    <url>/WebGoat/</url>
    <description>OpenSecLab: Actividad en WebGoat detectada</description>
    <group>openseclab_webgoat,</group>
  </rule>

  <!-- ══ Suricata IDS ═══════════════════════════════════════════════ -->

  <rule id="100050" level="10">
    <field name="event_type">alert</field>
    <field name="alert.category">Web Application Attack</field>
    <description>OpenSecLab: Suricata IDS — Ataque a aplicacion web: $(alert.signature)</description>
    <group>ids,suricata,openseclab,attack,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100051" level="10">
    <field name="event_type">alert</field>
    <field name="alert.category">A Network Trojan</field>
    <description>OpenSecLab: Suricata IDS — Trojan de red detectado: $(alert.signature)</description>
    <group>ids,suricata,openseclab,malware,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <rule id="100052" level="8">
    <field name="event_type">alert</field>
    <field name="alert.category">Attempted Information Leak</field>
    <description>OpenSecLab: Suricata IDS — Posible reconocimiento/escaneo: $(alert.signature)</description>
    <group>ids,suricata,openseclab,recon,</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <rule id="100053" level="8">
    <field name="event_type">alert</field>
    <field name="alert.category">Attempted User Privilege Gain</field>
    <description>OpenSecLab: Suricata IDS — Intento de escalada de privilegios: $(alert.signature)</description>
    <group>ids,suricata,openseclab,privilege_escalation,</group>
    <mitre>
      <id>T1068</id>
    </mitre>
  </rule>

  <!-- Regla genérica para otras alertas de Suricata -->
  <rule id="100059" level="6">
    <field name="event_type">alert</field>
    <description>OpenSecLab: Suricata IDS — Alerta: $(alert.signature) [$(alert.category)]</description>
    <group>ids,suricata,openseclab,</group>
  </rule>

  <!-- ══ OPSN API Vulnerable ════════════════════════════════════════ -->

  <!-- Regla base: identifica cualquier evento JSON de la API del lab -->
  <rule id="100060" level="0">
    <decoded_as>json</decoded_as>
    <field name="source">opsn-api</field>
    <description>OpenSecLab: Evento registrado por la API vulnerable (opsn-api)</description>
    <group>openseclab_api,</group>
  </rule>

  <!-- API1:2023 BOLA — lectura de perfil ajeno (IDOR) -->
  <rule id="100061" level="10">
    <if_sid>100060</if_sid>
    <field name="event">bola_attempt</field>
    <description>OpenSecLab API1 BOLA: Acceso a perfil de otro usuario. El servidor no verifica que el token pertenece al user_id solicitado — IDOR clasico.</description>
    <group>attack,bola,openseclab_api,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- API1:2023 BOLA — escritura de perfil ajeno -->
  <rule id="100062" level="12">
    <if_sid>100060</if_sid>
    <field name="event">bola_write_attempt</field>
    <description>OpenSecLab API1 BOLA (escritura): Modificacion de datos de otro usuario. BOLA con impacto de integridad — puede sobrescribir email, password u otros campos.</description>
    <group>attack,bola,openseclab_api,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- API3:2023 Mass Assignment -->
  <rule id="100063" level="12">
    <if_sid>100060</if_sid>
    <field name="event">mass_assignment_attempt</field>
    <description>OpenSecLab API3 Mass Assignment: Intento de modificar campos protegidos via PUT /profile. El servidor aplica todos los campos del JSON sin lista blanca — un atacante puede escalar su rol a admin.</description>
    <group>attack,mass_assignment,openseclab_api,</group>
    <mitre>
      <id>T1078.004</id>
    </mitre>
  </rule>

  <!-- API5:2023 Broken Function Level Authorization -->
  <rule id="100064" level="10">
    <if_sid>100060</if_sid>
    <field name="event">broken_function_auth</field>
    <description>OpenSecLab API5 Broken Function Level Auth: Usuario sin privilegios accedio a /api/admin/users. El endpoint existe y responde sin verificar el rol — cualquier token valido obtiene la lista completa de usuarios.</description>
    <group>attack,privilege_escalation,openseclab_api,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- API2:2023 Broken Authentication — login fallido -->
  <rule id="100065" level="5">
    <if_sid>100060</if_sid>
    <field name="event">login_failed</field>
    <description>OpenSecLab API2 Broken Auth: Login fallido en la API. Los tokens son estaticos y nunca expiran — una vez obtenido un token valido, es permanente.</description>
    <group>authentication_failed,openseclab_api,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>
