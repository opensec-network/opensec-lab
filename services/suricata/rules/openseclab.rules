# services/suricata/rules/openseclab.rules
# OpenSec Lab — Reglas Suricata personalizadas
# Detecta ataques a los servicios del laboratorio (172.18.0.0/16)
# SIDs reservados: 9000001-9000099

# ══ DVWA ════════════════════════════════════════════════════════════

alert http any any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - SQL Injection en DVWA"; \
    flow:established,to_server; \
    http.uri; content:"/vulnerabilities/sqli"; \
    pcre:"/(%27|\x27|--|\x3b|union|select|drop|insert|or\s+1)/i"; \
    classtype:web-application-attack; \
    sid:9000001; rev:2;)

alert http any any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - Command Injection en DVWA"; \
    flow:established,to_server; \
    http.uri; content:"/vulnerabilities/exec"; \
    http.request_body; pcre:"/(\x3b|\||&&|\x60|\$\()/i"; \
    classtype:web-application-attack; \
    sid:9000002; rev:2;)

alert http any any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - XSS en DVWA"; \
    flow:established,to_server; \
    http.uri; content:"/vulnerabilities/xss"; \
    pcre:"/(<script|javascript:|on\w+\s*=)/i"; \
    classtype:web-application-attack; \
    sid:9000003; rev:2;)

alert http any any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - File Inclusion en DVWA"; \
    flow:established,to_server; \
    http.uri; content:"/vulnerabilities/fi"; \
    pcre:"/(\.\.|\/etc\/|c:\\\\windows)/i"; \
    classtype:web-application-attack; \
    sid:9000004; rev:2;)

# ══ OWASP Juice Shop ════════════════════════════════════════════════

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - Acceso al Score Board de Juice Shop (descubrimiento de ruta oculta)"; \
    flow:established,to_server; \
    http.uri; content:"/score-board"; \
    classtype:policy-violation; \
    sid:9000010; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - SQL Injection en Juice Shop login"; \
    flow:established,to_server; \
    http.uri; content:"/rest/user/login"; \
    http.request_body; content:"' OR"; nocase; \
    classtype:web-application-attack; \
    sid:9000011; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - Intento de acceso a admin en Juice Shop"; \
    flow:established,to_server; \
    http.uri; content:"/rest/user/whoami"; \
    classtype:policy-violation; \
    sid:9000012; rev:1;)

# ══ Reconocimiento general ══════════════════════════════════════════

alert tcp $EXTERNAL_NET any -> $HOME_NET any ( \
    msg:"OpenSecLab - Escaneo de puertos SYN detectado"; \
    flags:S,12; \
    threshold:type threshold, track by_src, count 30, seconds 5; \
    classtype:attempted-recon; \
    sid:9000050; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab - Posible fuerza bruta HTTP"; \
    flow:established,to_server; \
    threshold:type threshold, track by_src, count 30, seconds 10; \
    classtype:attempted-user; \
    sid:9000051; rev:1;)

# ══ OPSN API Vulnerable ═════════════════════════════════════════════

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab API1 BOLA - Enumeracion de perfiles de usuario en la API"; \
    flow:established,to_server; \
    http.method; content:"GET"; \
    http.uri; content:"/api/users/"; content:"/profile"; distance:0; \
    threshold:type threshold, track by_src, count 5, seconds 10; \
    classtype:web-application-attack; \
    sid:9000060; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab API2 Broken Auth - Fuerza bruta en /api/auth/login"; \
    flow:established,to_server; \
    http.method; content:"POST"; \
    http.uri; content:"/api/auth/login"; \
    threshold:type threshold, track by_src, count 5, seconds 10; \
    classtype:attempted-user; \
    sid:9000061; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab API5 Broken Function Auth - Acceso a endpoint admin"; \
    flow:established,to_server; \
    http.method; content:"GET"; \
    http.uri; content:"/api/admin/users"; \
    classtype:policy-violation; \
    sid:9000062; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS ( \
    msg:"OpenSecLab API3 Mass Assignment - PUT a /profile con campo role"; \
    flow:established,to_server; \
    http.method; content:"PUT"; \
    http.uri; content:"/api/users/"; content:"/profile"; distance:0; \
    http.request_body; content:"\"role\""; \
    classtype:web-application-attack; \
    sid:9000063; rev:1;)

