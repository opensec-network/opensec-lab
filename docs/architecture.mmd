      "primaryTextColor": "#f1f5f9",
      "primaryBorderColor":"#475569",
      "lineColor":        "#64748b",
      "clusterBkg":       "#1a2235",
      "clusterBorder":    "#334155",
      "titleColor":       "#f8fafc",
      "edgeLabelBackground":"#0f172a",
