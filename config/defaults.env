# =============================================================================
# OpenSec Lab — Configuración por defecto
# =============================================================================
# Este archivo define los valores por defecto del lab.
# Para personalizar, copia este archivo como .env en ~/OpenSec_Lab/ y edítalo.
# Los cambios en .env no se sobreescriben al actualizar el lab.
# =============================================================================

# --- Dominio interno del lab ---
OPSN_DOMAIN=opensec.lab

# --- Red Docker ---
OPSN_NETWORK_NAME=openseclab

# --- Credenciales ---
OPSN_DNS_PASSWORD=Password
OPSN_MAIL_PASSWORD=Password
OPSN_MAIL_USER=user
OPSN_GOPHISH_PASSWORD=Password

# --- Puertos en el host ---
OPSN_DNS_CONSOLE_PORT=5380
OPSN_DVWA_PORT=8080
OPSN_JUICE_PORT=3000
OPSN_GOPHISH_ADMIN_PORT=3333
OPSN_GOPHISH_PHISH_PORT=80
OPSN_DESKTOP_PORT=3100
OPSN_DESKTOP_HTTPS_PORT=3101
OPSN_MAIL_WEBMAIL_PORT=8888

# --- Puertos de mail (cliente Thunderbird) ---
OPSN_MAIL_SMTP_PORT=587
OPSN_MAIL_IMAP_PORT=143

# --- GoPhish: configuración de campaña pre-creada ---
OPSN_GOPHISH_SMTP_PORT=25
OPSN_GOPHISH_FROM_NAME=Soporte IT

# --- GoPhish: identidad de empresa ficticia (Acme Corp) ---
OPSN_GOPHISH_COMPANY_NAME=Acme Corp
OPSN_GOPHISH_EMAIL_SUBJECT=Accion requerida: Restablece tu contrasena corporativa
OPSN_GOPHISH_SUPPORT_TEAM=Equipo de Seguridad IT

# --- Tier 1: Targets vulnerables adicionales ---
OPSN_WEBGOAT_PORT=8081

# --- Tier 2: Gamificacion y Aprendizaje ---
OPSN_GITEA_PORT=3002
OPSN_GITEA_SSH_PORT=2222
OPSN_GITEA_PASSWORD=Password
OPSN_GITEA_ADMIN_USER=admin
OPSN_PORTAL_PORT=8443

# --- Tier 3: Blue Team — Wazuh SIEM + Suricata IDS ---
# NOTA: Requiere 12+ GB RAM y vm.max_map_count=262144 en el host:
#   sudo sysctl -w vm.max_map_count=262144
#   echo 'vm.max_map_count=262144' | sudo tee -a /etc/sysctl.conf
#
# Contraseña de admin del Wazuh Indexer (OpenSearch) y Dashboard
# Requisitos: 8+ chars, mayúsculas, minúsculas, dígito, símbolo ($-_%@?.*&)
OPSN_WAZUH_PASSWORD=Password1.
# Contraseña del usuario wazuh-wui (API del Manager)
OPSN_WAZUH_API_PASSWORD=WazuhApiP4ss.
# Puerto del Wazuh Dashboard (HTTPS)
OPSN_WAZUH_DASH_PORT=5601
# Puerto de la API REST del Wazuh Manager
OPSN_WAZUH_API_PORT=55000
# Interfaz que Suricata monitorea (auto-detectada en Linux; "any" en macOS)
OPSN_SURICATA_INTERFACE=any
# Opciones JVM del Indexer OpenSearch (reducir en equipos con <8 GB RAM)
OPSN_WAZUH_INDEXER_JAVA_OPTS=-Xms1g -Xmx1g -Djava.security.manager=allow
